NEXT_PUBLIC_SITE_URL=https://www.d2p.com.tr
NEXT_PUBLIC_SUPABASE_URL=https://vurzmpbwlgahzbilqsfa.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Tawk.to — Admin > Property > Administration > Chat Widget > Direct Chat Link
# Örnek link: https://tawk.to/chat/PROPERTY_ID/WIDGET_ID
NEXT_PUBLIC_TAWK_ENABLED=false
NEXT_PUBLIC_TAWK_PROPERTY_ID=your-property-id
NEXT_PUBLIC_TAWK_WIDGET_ID=default

# Edge Function / Next.js server secrets (repoya EKLEMEYİN — .env.local + Vercel)
# WEBHOOK_SECRET=your-long-random-secret
# RESEND_API_KEY=re_xxxxxxxx  (Vercel + Supabase secrets; eğitmen bildirim mailleri için gerekli)
# SUPABASE_SERVICE_ROLE_KEY=eyJ... (Next server + Edge Function; asla NEXT_PUBLIC_ yapma)
# STUDENT_JWT_SECRET=en-az-32-karakter-bagimsiz-secret (Supabase JWT secret ile aynı olmasın)

# Yerel sertifika PDF üretimi (opsiyonel — Chrome yolu)
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Vercel'de Chromium paketi (chromium-min). Sürüm @sparticuz/chromium-min ile aynı olmalı.
# CHROMIUM_PACK_URL=https://github.com/Sparticuz/chromium/releases/download/v149.0.0/chromium-v149.0.0-pack.x64.tar
